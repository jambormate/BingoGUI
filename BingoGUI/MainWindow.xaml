<Window x:Class="BingoGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BingoGUI"
        mc:Ignorable="d"
        Title="Bingo" Height="450" Width="300">
    <Grid>
        <StackPanel Margin="10">

            <Button x:Name="btnGeneral"
                    Content="Kártya generálása"
                    Height="30"
                    Margin="0,0,0,10"
                    Click="btnGeneral_Click"/>

            <UniformGrid x:Name="gridKartya"
                         Rows="5"
                         Columns="5"
                         Margin="0,0,0,10"/>

            <TextBox x:Name="txtFajlnev"
                     Text="bingo.txt"
                     Height="25"
                     Margin="0,0,0,5"/>

            <Button x:Name="btnMentes"
                    Content="Mentés"
                    Height="30"
                    Click="btnMentes_Click"/>

        </StackPanel>
    </Grid>
</Window>
